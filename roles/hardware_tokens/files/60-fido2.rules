# Generic FIDO/U2F device udev rules
# Allow access for users in plugdev group

# FIDO Alliance HID standard
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="*", ATTRS{idProduct}=="*", TAG+="uaccess", GROUP="plugdev", MODE="0660"

# U2F Zero
SUBSYSTEM=="usb", ATTR{idVendor}=="10c4", ATTR{idProduct}=="8acf", MODE="0660", GROUP="plugdev"

# SoloKeys
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="a2ca", MODE="0660", GROUP="plugdev"

# Thetis FIDO2
SUBSYSTEM=="usb", ATTR{idVendor}=="1ea8", ATTR{idProduct}=="f025", MODE="0660", GROUP="plugdev"

# Google Titan
SUBSYSTEM=="usb", ATTR{idVendor}=="18d1", ATTR{idProduct}=="5026", MODE="0660", GROUP="plugdev"

# Feitian
SUBSYSTEM=="usb", ATTR{idVendor}=="096e", MODE="0660", GROUP="plugdev"

# HyperFIDO
SUBSYSTEM=="usb", ATTR{idVendor}=="2ccf", MODE="0660", GROUP="plugdev"
