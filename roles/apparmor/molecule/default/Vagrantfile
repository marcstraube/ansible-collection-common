# marcstraube.common.apparmor/molecule/default/Vagrantfile
# No Rocky Linux — RHEL/Rocky uses SELinux, not AppArmor
#
# MOLECULE_PLATFORM_NAME filters which VM to create.

platform = ENV['MOLECULE_PLATFORM_NAME'] || ''

Vagrant.configure("2") do |config|
  config.vm.box_check_update = false
  config.vm.synced_folder ".", "/vagrant", disabled: true

  if platform.empty? || platform == "apparmor-archlinux"
    config.vm.define "apparmor-archlinux" do |node|
      node.vm.box = "marcstraube/archlinux-ansible"
      node.vm.hostname = "apparmor-archlinux"
      node.vm.network "forwarded_port", guest: 22, host: 2222, id: "ssh", auto_correct: false

      node.vm.provider "virtualbox" do |vb|
        vb.memory = "1024"
        vb.cpus = 1
        vb.name = "molecule-apparmor-archlinux"
      end
    end
  end

  if platform.empty? || platform == "apparmor-debian-trixie"
    config.vm.define "apparmor-debian-trixie" do |node|
      node.vm.box = "cloud-image/debian-13"
      node.vm.hostname = "apparmor-debian-trixie"
      node.vm.network "forwarded_port", guest: 22, host: 2223, id: "ssh", auto_correct: false

      node.vm.provider "virtualbox" do |vb|
        vb.memory = "1024"
        vb.cpus = 1
        vb.name = "molecule-apparmor-debian-trixie"
      end
    end
  end
end
