{{ ansible_managed | comment }}
## Audit Rules

## Remove any existing rules
-D

## Buffer Size
-b {{ auditd_buffer_size }}

## Failure Mode
## 0=silent 1=printk 2=panic
-f {{ auditd_failure_mode }}

## Backlog wait time
--backlog_wait_time {{ auditd_backlog_wait_time }}

###############################################################################
## Time Changes (Compliance: PCI-DSS, HIPAA, NIST, STIG)
###############################################################################
{% if auditd_time_change or auditd_pci_dss or auditd_hipaa or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -S adjtimex,settimeofday -k time-change
-a always,exit -F arch=b32 -S adjtimex,settimeofday,stime -k time-change
-a always,exit -F arch=b64 -S clock_settime -k time-change
-a always,exit -F arch=b32 -S clock_settime -k time-change
-w /etc/localtime -p wa -k time-change
{% endif %}

###############################################################################
## User/Group Changes (Compliance: All)
###############################################################################
{% if auditd_identity_change or auditd_pci_dss or auditd_hipaa or auditd_nist or auditd_stig %}
-w /etc/group -p wa -k identity
-w /etc/passwd -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity
{% endif %}

###############################################################################
## Network Configuration Changes
###############################################################################
{% if auditd_network_change or auditd_pci_dss or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -S sethostname,setdomainname -k system-locale
-a always,exit -F arch=b32 -S sethostname,setdomainname -k system-locale
-w /etc/issue -p wa -k system-locale
-w /etc/issue.net -p wa -k system-locale
-w /etc/hosts -p wa -k system-locale
-w /etc/network -p wa -k system-locale
-w /etc/networks -p wa -k system-locale
{% endif %}

###############################################################################
## System Locale Changes
###############################################################################
{# Only emit sethostname/setdomainname if not already covered by Network section #}
{% if auditd_system_locale or auditd_nist or auditd_stig %}
{% if not (auditd_network_change or auditd_pci_dss or auditd_nist or auditd_stig) %}
-a always,exit -F arch=b64 -S sethostname,setdomainname -k system-locale
-a always,exit -F arch=b32 -S sethostname,setdomainname -k system-locale
{% endif %}
{% endif %}

###############################################################################
## MAC Policy Changes (SELinux/AppArmor)
###############################################################################
{% if auditd_mac_policy or auditd_pci_dss or auditd_nist or auditd_stig %}
-w /etc/selinux/ -p wa -k MAC-policy
-w /etc/apparmor/ -p wa -k MAC-policy
-w /etc/apparmor.d/ -p wa -k MAC-policy
-w /usr/share/selinux/ -p wa -k MAC-policy
{% endif %}

###############################################################################
## Login/Logout Events
###############################################################################
{% if auditd_logins or auditd_pci_dss or auditd_hipaa or auditd_nist or auditd_stig %}
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/run/faillock/ -p wa -k logins
{% endif %}

###############################################################################
## Session Initiation
###############################################################################
{% if auditd_session or auditd_pci_dss or auditd_hipaa or auditd_nist or auditd_stig %}
-w /var/run/utmp -p wa -k session
-w /var/log/wtmp -p wa -k session
-w /var/log/btmp -p wa -k session
{% endif %}

###############################################################################
## Permission Changes (chmod, chown, etc.)
###############################################################################
{% if auditd_perm_mod or auditd_pci_dss or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S setxattr,lsetxattr,fsetxattr,removexattr,lremovexattr,fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S setxattr,lsetxattr,fsetxattr,removexattr,lremovexattr,fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod
{% endif %}

###############################################################################
## Unsuccessful File Access Attempts
###############################################################################
{% if auditd_access or auditd_pci_dss or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -S open,openat,creat,truncate,ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b32 -S open,openat,creat,truncate,ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b64 -S open,openat,creat,truncate,ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b32 -S open,openat,creat,truncate,ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access
{% endif %}

###############################################################################
## File Deletions
###############################################################################
{% if auditd_delete or auditd_pci_dss or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat -F auid>=1000 -F auid!=4294967295 -k delete
-a always,exit -F arch=b32 -S unlink,unlinkat,rename,renameat -F auid>=1000 -F auid!=4294967295 -k delete
{% endif %}

###############################################################################
## Sudoers Changes
###############################################################################
{% if auditd_scope or auditd_pci_dss or auditd_nist or auditd_stig %}
-w /etc/sudoers -p wa -k scope
-w /etc/sudoers.d/ -p wa -k scope
{% endif %}

###############################################################################
## Sudo Usage
###############################################################################
{% if auditd_actions or auditd_pci_dss or auditd_hipaa or auditd_nist or auditd_stig %}
-a always,exit -F arch=b64 -C euid!=uid -F euid=0 -S execve -k actions
-a always,exit -F arch=b32 -C euid!=uid -F euid=0 -S execve -k actions
{% endif %}

###############################################################################
## Kernel Module Changes
###############################################################################
{% if auditd_modules or auditd_pci_dss or auditd_nist or auditd_stig %}
-w /sbin/insmod -p x -k modules
-w /sbin/rmmod -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k modules
-a always,exit -F arch=b32 -S init_module,finit_module,delete_module -k modules
{% endif %}

###############################################################################
## Custom File Watches
###############################################################################
{% for watch in auditd_watches %}
-w {{ watch.path }} -p {{ watch.permissions }} -k {{ watch.key }}
{% endfor %}

{% for watch in auditd_custom_watches %}
-w {{ watch.path }} -p {{ watch.permissions }} -k {{ watch.key }}
{% endfor %}

###############################################################################
## Make Configuration Immutable
## NOTE: This MUST be last! After this, rules cannot be changed without reboot
###############################################################################
{% if auditd_rules_immutable %}
-e 2
{% endif %}
