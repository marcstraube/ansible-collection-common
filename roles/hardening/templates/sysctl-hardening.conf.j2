{{ ansible_managed | comment }}
# Kernel hardening parameters

{% for key, value in hardening_kernel_settings.items() %}
{{ key }} = {{ value }}
{% endfor %}
{% if hardening_kernel_perf_event_paranoid_enabled | bool %}

# Restrict perf events (3 on Arch/Debian, 2 on RedHat — value 3 is not upstream)
{% if ansible_facts['os_family'] in ['Archlinux', 'Debian'] %}
kernel.perf_event_paranoid = 3
{% else %}
kernel.perf_event_paranoid = 2
{% endif %}
{% endif %}
{% if hardening_kernel_io_uring_disabled is defined and ansible_facts['kernel'] is version('6.6', '>=') %}

# Disable io_uring (0=open, 1=unprivileged blocked, 2=all blocked)
kernel.io_uring_disabled = {{ hardening_kernel_io_uring_disabled }}
{% endif %}
