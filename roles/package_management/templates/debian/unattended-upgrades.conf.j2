{{ ansible_managed | comment('c') }}
// Unattended Upgrades Configuration

Unattended-Upgrade::Allowed-Origins {
{% for origin in apt_unattended_origins %}
    "{{ origin }}";
{% endfor %}
};

// Automatically reboot if needed
Unattended-Upgrade::Automatic-Reboot "{{ apt_unattended_auto_reboot | bool | lower }}";
{% if apt_unattended_auto_reboot | bool %}
Unattended-Upgrade::Automatic-Reboot-Time "{{ apt_unattended_reboot_time }}";
{% endif %}
{% if apt_unattended_mail | length > 0 %}

// Email notifications
Unattended-Upgrade::Mail "{{ apt_unattended_mail }}";
Unattended-Upgrade::MailOnlyOnError "{{ apt_unattended_mail_on_error | bool | lower }}";
{% endif %}

// Remove unused dependencies
Unattended-Upgrade::Remove-Unused-Dependencies "{{ apt_unattended_autoremove | bool | lower }}";
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";

// Verbose logging
Unattended-Upgrade::Verbose "false";
