{{ ansible_managed | comment }}
# Reflector configuration file for the systemd service.
#
# Empty lines and lines beginning with "#" are ignored.  All other lines should
# contain valid reflector command-line arguments. The lines are parsed with
# Python's shlex modules so standard shell syntax should work. All arguments are
# collected into a single argument list.
#
# See "reflector --help" for details.

# Set the output path where the mirrorlist will be saved (--save).
--save /etc/pacman.d/mirrorlist

# Select the transfer protocol (--protocol).
--protocol {{ reflector.protocol }}

# Select the country (--country).
# Consult the list of available countries with "reflector --list-countries" and
# select the countries nearest to you or the ones that you trust.
{% if reflector.countries | length > 0 %}
--country {{ reflector.countries | join(',') }}
{% else %}
# No country filter - using global mirrors
{% endif %}

# Use only the most recently synchronized mirrors (--latest).
--latest {{ reflector.latest }}

# Sort the mirrors (--sort).
# Options: age, rate, country, score, delay
--sort {{ reflector.sort }}

{% if reflector.age | default('') %}
# Maximum age of mirrors in hours (--age).
--age {{ reflector.age }}
{% endif %}
{% if reflector.score | default('') %}

# Minimum mirror score (--score).
--score {{ reflector.score }}
{% endif %}

# Cache the mirrorlist
--cache-timeout 300
